# Copy to .env and adjust for your XAMPP setup
# Make sure MySQL is running in XAMPP Control Panel!
# Create database "eparduotuve" in phpMyAdmin (http://localhost/phpmyadmin)

DATABASE_URL="mysql://root@localhost:3306/eparduotuve"

# Prisma adapter (optional - defaults work for XAMPP)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=eparduotuve
