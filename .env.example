# Copy to .env — dabartinė schema naudoja SQLite (žr. prisma/schema.prisma).
# Lokaliai:
DATABASE_URL="file:./prisma/dev.db"

# Docker (docker compose): DB laikomas tomu, šios eilutės kurti .env nebūtina —
# compose nustato DATABASE_URL=file:/data/database.db

# Senas XAMPP / MySQL pavyzdys (tik jei pereinate prie mysql provider schema):
# DATABASE_URL="mysql://root@localhost:3306/eparduotuve"

# Prisma adapter (optional - defaults work for XAMPP)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=eparduotuve
